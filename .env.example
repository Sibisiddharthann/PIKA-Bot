# Copy to .env and fill in. Used for LOCAL testing only.
# (In GitHub Actions these come from repo Secrets, not this file.)
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-from-botfather
TELEGRAM_CHAT_ID=123456789
# Optional — free key from https://aistudio.google.com to summarize each article:
GEMINI_API_KEY=
# Optional — Gemini model (default gemini-2.0-flash):
GEMINI_MODEL=gemini-2.0-flash
# Optional — number of stories (default 8):
NEWS_STORY_COUNT=8
